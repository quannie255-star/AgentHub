# AgentHub Environment Variables
# Copy this file to .env and fill in your values.
# docker compose reads .env automatically.

# --- LLM Configuration ---
# API key for Claude (Anthropic) or your LLM provider
AGENTHUB_LLM_API_KEY=sk-ant-...
AGENTHUB_LLM_MODEL=claude-sonnet-4-6
# AGENTHUB_LLM_BASE_URL=https://api.anthropic.com
# AGENTHUB_LLM_MAX_TOKENS=4096

# --- Orchestrator ---
# AGENTHUB_ORCHESTRATOR_RETRIES=3
# AGENTHUB_ORCHESTRATOR_TIMEOUT=60.0
# AGENTHUB_ORCHESTRATOR_FALLBACK=claude

# --- Storage ---
# AGENTHUB_STORAGE_TYPE=sqlite
# AGENTHUB_STORAGE_PATH=data/agenthub.db

# --- Logging ---
# AGENTHUB_LOG_LEVEL=info

# --- Ports (host-side) ---
# AGENTHUB_BACKEND_PORT=8000
# AGENTHUB_FRONTEND_PORT=8501
