# AgentHub Frontend — Streamlit UI
FROM python:3.11-slim

LABEL org.opencontainers.image.title="AgentHub Frontend"
LABEL org.opencontainers.image.description="Multi-Agent Collaboration Platform — Streamlit UI"

WORKDIR /app

# --- System dependencies ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# --- Python dependencies (layer cache friendly) ---
COPY pyproject.toml ./
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
    "pydantic>=2.0" \
    "streamlit>=1.35.0" \
    "httpx>=0.27.0" \
    "pyyaml>=6.0"

# --- Application code (UI only — lightweight) ---
COPY src/ ./src/
COPY README.md ./

# --- Backend API URL (override via docker-compose or -e) ---
ENV AGENTHUB_API_URL=http://backend:8000

# --- Health check ---
HEALTHCHECK --interval=20s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8501/_stcore/health || exit 1

EXPOSE 8501

CMD ["streamlit", "run", "src/ui/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--browser.serverAddress=localhost", \
     "--theme.font=monospace"]
